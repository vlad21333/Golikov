<Window x:Class="Golikov.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Калькулятор" Height="550" Width="400" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Поле для ввода и отображения результата -->
        <TextBox x:Name="InputBox" 
                 Grid.Row="0" 
                 FontSize="36" 
                 FontWeight="Bold"
                 HorizontalAlignment="Stretch" 
                 Margin="5" 
                 Padding="10"
                 IsReadOnly="True"
                 Background="White"
                 TextAlignment="Right"
                 Text="0"/>

        <!-- Панель с кнопками -->
        <Grid Grid.Row="1" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 1-й ряд -->
            <Button x:Name="Btn7" Content="7" Grid.Row="0" Grid.Column="0" Click="Number_Click" FontSize="20" Margin="2"/>
            <Button x:Name="Btn8" Content="8" Grid.Row="0" Grid.Column="1" Click="Number_Click" FontSize="20" Margin="2"/>
            <Button x:Name="Btn9" Content="9" Grid.Row="0" Grid.Column="2" Click="Number_Click" FontSize="20" Margin="2"/>
            <Button x:Name="BtnDivide" Content="/" Grid.Row="0" Grid.Column="3" Click="Operation_Click" FontSize="20" Margin="2" Background="#FFE6E6E6"/>

            <!-- 2-й ряд -->
            <Button x:Name="Btn4" Content="4" Grid.Row="1" Grid.Column="0" Click="Number_Click" FontSize="20" Margin="2"/>
            <Button x:Name="Btn5" Content="5" Grid.Row="1" Grid.Column="1" Click="Number_Click" FontSize="20" Margin="2"/>
            <Button x:Name="Btn6" Content="6" Grid.Row="1" Grid.Column="2" Click="Number_Click" FontSize="20" Margin="2"/>
            <Button x:Name="BtnMultiply" Content="*" Grid.Row="1" Grid.Column="3" Click="Operation_Click" FontSize="20" Margin="2" Background="#FFE6E6E6"/>

            <!-- 3-й ряд -->
            <Button x:Name="Btn1" Content="1" Grid.Row="2" Grid.Column="0" Click="Number_Click" FontSize="20" Margin="2"/>
            <Button x:Name="Btn2" Content="2" Grid.Row="2" Grid.Column="1" Click="Number_Click" FontSize="20" Margin="2"/>
            <Button x:Name="Btn3" Content="3" Grid.Row="2" Grid.Column="2" Click="Number_Click" FontSize="20" Margin="2"/>
            <Button x:Name="BtnMinus" Content="-" Grid.Row="2" Grid.Column="3" Click="Operation_Click" FontSize="20" Margin="2" Background="#FFE6E6E6"/>

            <!-- 4-й ряд -->
            <Button x:Name="Btn0" Content="0" Grid.Row="3" Grid.Column="0" Click="Number_Click" FontSize="20" Margin="2"/>
            <Button x:Name="BtnDot" Content="." Grid.Row="3" Grid.Column="1" Click="Dot_Click" FontSize="20" Margin="2"/>
            <Button x:Name="BtnPower" Content="^" Grid.Row="3" Grid.Column="2" Click="Operation_Click" FontSize="20" Margin="2" Background="#FFE6E6E6"/>
            <Button x:Name="BtnPlus" Content="+" Grid.Row="3" Grid.Column="3" Click="Operation_Click" FontSize="20" Margin="2" Background="#FFE6E6E6"/>

            <!-- 5-й ряд -->
            <Button x:Name="BtnClear" Content="C" Grid.Row="4" Grid.Column="0" Click="Clear_Click" FontSize="20" Margin="2,2,3,2" Background="#FFFFA07A" Grid.ColumnSpan="2"/>
            <Button x:Name="BtnEquals" Content="=" Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="2" Click="Equals_Click" FontSize="20" Margin="2" Background="#FF90EE90"/>

        </Grid>
    </Grid>
</Window>